# Default to Git's normal text detection, then pin Unity text assets to LF.
* text=auto

# Repository metadata and documentation
.gitattributes text eol=lf
.gitignore text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Source files
*.cs text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.compute text eol=lf

# Unity serialized text assets
*.meta text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.overrideController text eol=lf
*.playable text eol=lf
*.physicMaterial text eol=lf
*.physicsMaterial2D text eol=lf
*.renderTexture text eol=lf
*.mask text eol=lf

# Images and texture sources
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.tga binary
*.tif binary
*.tiff binary
*.psd binary
*.exr binary
*.hdr binary
*.ico binary

# Audio and video
*.wav binary
*.mp3 binary
*.ogg binary
*.flac binary
*.mp4 binary
*.mov binary
*.webm binary

# Models, archives, plugins, and generated binaries
*.fbx binary
*.blend binary
*.vrm binary
*.glb binary
*.gltf binary
*.bytes binary
*.dll binary
*.exe binary
*.pdb binary
*.zip binary
*.7z binary
*.rar binary
